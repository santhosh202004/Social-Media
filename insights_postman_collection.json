				{
					"name": "5. Page & Profile Analytics",
					"item": [
						{
							"name": "Facebook Page-Level Metrics (Current)",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/{{pageId}}/insights?metric=page_impressions_unique,page_video_views,page_post_engagements,page_views_total&period=day&since={{sinceTimestamp}}&until={{untilTimestamp}}&access_token={{pageAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"{{pageId}}",
										"insights"
									],
									"query": [
										{
											"key": "metric",
											"value": "page_impressions_unique,page_video_views,page_post_engagements,page_views_total"
										},
										{
											"key": "period",
											"value": "day"
										},
										{
											"key": "since",
											"value": "{{sinceTimestamp}}"
										},
										{
											"key": "until",
											"value": "{{untilTimestamp}}"
										},
										{
											"key": "access_token",
											"value": "{{pageAccessToken}}"
										}
									]
								},
								"description": "Gathers daily Page impressions, views, actions, and engagements for the active time period."
							},
							"response": []
						},
