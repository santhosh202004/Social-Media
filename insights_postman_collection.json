									"query": [
										{
											"key": "metric",
											"value": "reach,views,likes,comments,shares,saved,total_interactions,ig_reels_avg_watch_time,ig_reels_video_view_total_time"
										},
										{
											"key": "access_token",
											"value": "{{userAccessToken}}"
										}
									]
								},
								"description": "Fetches dedicated Instagram Reels playback views, interaction volumes, and watch retention times."
							},
							"response": []
						},
						{
							"name": "Instagram Insights - Story Metrics",
							"request": {
								"method": "GET",
