							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/{{mediaId}}/insights?metric=navigation&breakdown=story_navigation_action_type&access_token={{userAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"{{mediaId}}",
										"insights"
									],
									"query": [
										{
											"key": "metric",
