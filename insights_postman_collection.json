{
	"info": {
		"_postman_id": "c1f7b8fb-8fa3-43ef-adbf-9b98cecae834",
		"name": "AdMetrics Insights API Collection",
		"description": "Postman collection containing both the local PHP Controller and all backend third-party Meta/Instagram Graph API endpoints used by the Insights page.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Local PHP Controller",
			"item": [
				{
					"name": "Fetch Insights Local Controller",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/fetch_insights.php?since={{since}}&until={{until}}&nocache=1",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"fetch_insights.php"
							],
							"query": [
								{
									"key": "since",
									"value": "{{since}}",
									"description": "Start date (YYYY-MM-DD)"
								},
								{
									"key": "until",
									"value": "{{until}}",
									"description": "End date (YYYY-MM-DD)"
								},
								{
									"key": "nocache",
									"value": "1",
									"description": "Bypass local SimpleCache"
								}
							]
						},
						"description": "Hits your local PHP server to run the full aggregated insight pipeline."
					},
					"response": []
				}
			]
		},
		{
			"name": "Meta Graph API v19.0",
			"item": [
				{
					"name": "1. Discovery & Token Exchange",
					"item": [
						{
							"name": "Exchange User Token for Page Tokens",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/me/accounts?fields=id,name,access_token&access_token={{userAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"me",
										"accounts"
									],
									"query": [
										{
											"key": "fields",
											"value": "id,name,access_token"
										},
										{
											"key": "access_token",
											"value": "{{userAccessToken}}"
										}
									]
								},
								"description": "Retrieves pages managed by the active user token and gets the respective Page Access Tokens."
							},
							"response": []
						},
						{
							"name": "Validate Account Token (/me)",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/me?fields=id,name&access_token={{userAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"me"
									],
									"query": [
										{
											"key": "fields",
											"value": "id,name"
										},
										{
											"key": "access_token",
											"value": "{{userAccessToken}}"
										}
									]
								},
								"description": "Basic fallback check to confirm identity of the active token."
							},
							"response": []
						},
						{
							"name": "Discover Instagram Business Account ID",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/{{pageId}}?fields=instagram_business_account&access_token={{pageAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"{{pageId}}"
									],
									"query": [
										{
											"key": "fields",
											"value": "instagram_business_account"
										},
										{
											"key": "access_token",
											"value": "{{pageAccessToken}}"
										}
									]
								},
								"description": "Queries the Facebook Page's metadata to discover its linked Instagram Business Account ID."
							},
							"response": []
						}
					]
				},
				{
					"name": "2. Facebook Published Posts",
					"item": [
						{
							"name": "Fetch Facebook Published Posts & Post Insights",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/{{pageId}}/published_posts?fields=id,message,created_time,permalink_url,full_picture,attachments{media_type,type},reactions.summary(total_count),comments.summary(total_count),shares,insights.metric(post_impressions_unique,post_clicks,post_reactions_like_total,post_video_views){values}&limit=50&access_token={{pageAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"{{pageId}}",
										"published_posts"
									],
									"query": [
										{
											"key": "fields",
											"value": "id,message,created_time,permalink_url,full_picture,attachments{media_type,type},reactions.summary(total_count),comments.summary(total_count),shares,insights.metric(post_impressions_unique,post_clicks,post_reactions_like_total,post_video_views){values}"
										},
										{
											"key": "limit",
											"value": "50"
										},
										{
											"key": "access_token",
											"value": "{{pageAccessToken}}"
										}
									]
								},
								"description": "Loads the published posts feed on the Facebook Page with nested impressions, clicks, shares, and reactions."
							},
							"response": []
						}
					]
				},
				{
					"name": "3. Instagram Media & Active Stories",
					"item": [
						{
							"name": "Fetch Instagram Media List",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/{{igUserId}}/media?fields=id,caption,media_type,media_url,permalink,timestamp,like_count,comments_count,media_product_type&limit=50&access_token={{userAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"{{igUserId}}",
										"media"
									],
									"query": [
										{
											"key": "fields",
											"value": "id,caption,media_type,media_url,permalink,timestamp,like_count,comments_count,media_product_type"
										},
										{
											"key": "limit",
											"value": "50"
										},
										{
											"key": "access_token",
											"value": "{{userAccessToken}}"
										}
									]
								},
								"description": "Retrieves the list of IG Media objects published by the business profile."
							},
							"response": []
						},
						{
							"name": "Fetch Instagram Active Stories",
							"request": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "https://graph.facebook.com/v19.0/{{igUserId}}/stories?fields=id,caption,media_type,media_url,permalink,timestamp,like_count,comments_count,media_product_type&access_token={{userAccessToken}}",
									"protocol": "https",
									"host": [
										"graph",
										"facebook",
										"com"
									],
									"path": [
										"v19.0",
										"{{igUserId}}",
										"stories"
									],
									"query": [
										{
											"key": "fields",
											"value": "id,caption,media_type,media_url,permalink,timestamp,like_count,comments_count,media_product_type"
										},
										{
											"key": "access_token",
											"value": "{{userAccessToken}}"
										}
									]
								},
								"description": "Loads all active stories published within the past 24 hours."
							},
							"response": []
						}
					]
				},
