									"raw": "https://graph.facebook.com/v19.0/{{mediaId}}/insights?metric=reach,views,likes,comments,shares,saved,total_interactions,ig_reels_avg_watch_time,ig_reels_video_view_total_time&access_token={{userAccessToken}}",
									"protocol": "https",
